<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Savannah Stories & Hauntings Tour - Free Interactive Ghost Tour</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Georgia,serif;background:#1a1410;overflow:hidden}
.tour-container{display:flex;height:100vh}
#map{flex:1;background:#2a2520}
.sidebar{width:420px;background:linear-gradient(180deg,#3d2817,#2a1810);border-left:3px solid #8b7355;overflow-y:auto;padding:20px;box-shadow:-5px 0 20px rgba(0,0,0,0.5)}
.header{text-align:center;border-bottom:2px solid #8b7355;padding-bottom:12px;margin-bottom:12px}
.header h1{font-size:18px;color:#c9a876;margin-bottom:5px}
.header p{font-size:9px;color:#8b7355}
.voice-selector{margin:10px 0;padding:8px;background:rgba(139,115,85,0.1);border-radius:3px}
.voice-selector label{font-size:9px;color:#c9a876;display:block;margin-bottom:5px}
.voice-selector select{width:100%;padding:5px;background:#2a1810;color:#c9a876;border:1px solid #8b7355;border-radius:3px;font-size:9px}
.stats{background:rgba(139,115,85,0.1);border:1px solid #8b7355;border-radius:4px;padding:10px;margin-bottom:10px;font-size:10px}
.stats h3{color:#c9a876;margin-bottom:5px}
.stat-item{display:flex;justify-content:space-between;margin-bottom:3px}
.location-list{display:flex;flex-direction:column;gap:6px;margin-bottom:10px;max-height:300px;overflow-y:auto}
.location-card{background:rgba(139,115,85,0.08);border-left:4px solid #8b7355;padding:8px;border-radius:3px;cursor:pointer;transition:all 0.3s;font-size:9px}
.location-card:hover{background:rgba(139,115,85,0.15);border-color:#c9a876}
.location-card.active{background:rgba(201,168,118,0.2);border-color:#c9a876}
.location-name{font-size:11px;font-weight:bold;color:#c9a876;margin-bottom:2px}
.location-type{font-size:8px;color:#8b7355}
.location-story{font-size:9px;color:#a89968;line-height:1.3;margin-top:4px}
button{width:100%;padding:8px;background:linear-gradient(135deg,#8b7355,#6b5344);color:#f5f5dc;border:none;border-radius:3px;cursor:pointer;font-size:10px;font-weight:bold;text-transform:uppercase;box-shadow:0 0 10px rgba(139,115,85,0.3);margin-top:10px;transition:all 0.3s}
button:hover{background:linear-gradient(135deg,#a89968,#8b7d60)}
.proximity-alert{display:none;background:rgba(201,168,118,0.2);border:2px solid #c9a876;padding:10px;margin-top:10px;border-radius:3px;color:#c9a876;font-size:9px;text-align:center}
@media(max-width:1024px){.tour-container{flex-direction:column}#map{height:60%}.sidebar{width:100%;height:40%;border-left:none;border-top:3px solid #8b7355}}
.location-dot{width:20px;height:20px;border-radius:50%;cursor:pointer;border:2px solid #8b7355;display:flex;align-items:center;justify-content:center}
.location-dot.haunted div{width:14px;height:14px;border-radius:50%;background:#c9a876;box-shadow:0 0 10px rgba(201,168,118,0.5)}
.location-dot.blessed div{width:14px;height:14px;border-radius:50%;background:#66bb6a;box-shadow:0 0 10px rgba(102,187,106,0.5)}
.location-dot:hover div{transform:scale(1.3)}
.location-label{background:rgba(0,0,0,0.7) !important;color:#c9a876 !important;border:none !important;border-radius:3px;padding:4px 8px !important;font-size:11px !important;font-family:Georgia,serif;font-weight:bold;white-space:nowrap;box-shadow:0 2px 8px rgba(0,0,0,0.5)}
.coord-editor{display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#2a1810;border:2px solid #8b7355;padding:20px;border-radius:5px;z-index:1000;width:400px;box-shadow:0 0 30px rgba(0,0,0,0.8)}
.coord-editor.active{display:block}
.coord-editor h3{color:#c9a876;margin-bottom:15px;font-size:14px}
.coord-editor label{color:#a89968;display:block;margin-top:10px;font-size:11px}
.coord-editor input{width:100%;padding:8px;margin-top:5px;background:#1a1410;color:#c9a876;border:1px solid #8b7355;border-radius:3px;font-family:monospace;font-size:12px;box-sizing:border-box}
.coord-editor .buttons{display:flex;gap:10px}
.coord-editor button{flex:1;padding:10px;margin-top:15px;background:#8b7355;color:#f5f5dc;border:none;border-radius:3px;cursor:pointer;font-size:11px}
.coord-editor button:hover{background:#a89968}
.coord-editor .close{position:absolute;top:10px;right:15px;cursor:pointer;color:#c9a876;font-size:20px;font-weight:bold}
.coord-editor .close:hover{color:#d4c5b9}
</style>
</head>
<body>
<div class="tour-container">
<div id="map"></div>
<div class="sidebar">
<div class="header">
<h1>Savannah Stories & Hauntings</h1>
<p>FREE INTERACTIVE TOUR - 48 LOCATIONS</p>
<div style="margin-top:8px;padding:8px;background:rgba(102,187,106,0.1);border-radius:3px;font-size:9px;color:#66bb6a;cursor:pointer;text-align:center;border:1px solid #66bb6a;display:none" id="adminBadge" onclick="toggleAdminMode()">✓ ADMIN MODE ACTIVE</div>
</div>
<div class="voice-selector">
<label>Tour Guide Voice:</label>
<select id="voiceSelect">
<option value="OldLady">👵 Old Lady</option>
<option value="OldMan">👴 Old Man</option>
</select>
</div>
<div class="stats">
<h3>Tour Map</h3>
<div class="stat-item"><span>Total Locations:</span><strong id="totalCount">0</strong></div>
<div class="stat-item"><span>Haunted:</span><strong id="hauntedCount">0</strong></div>
<div class="stat-item"><span>Blessed Safe Spaces:</span><strong id="blessedCount">0</strong></div>
</div>
<div class="location-list" id="locationList"></div>
<button id="adminButton" onclick="promptAdminMode()" style="display:none;background:#c9534f">🔓 Unlock Admin</button>
<button id="editButton1" onclick="addNewLocation()" style="display:none">➕ Add New Location</button>
<button id="editButton2" onclick="exportLocations()" style="display:none">💾 Export Data</button>
<button onclick="centerMap()">📍 Center Map</button>
<button onclick="startGeofencing()">🔊 Enable Voice Proximity</button>
<div class="proximity-alert" id="proximityAlert"></div>
</div>
</div>
<audio id="narrationAudio" style="display:none"></audio>

<div class="coord-editor" id="coordEditor">
<div class="close" onclick="closeCoordEditor()">&times;</div>
<h3>Edit Location</h3>
<label>Location Name:</label>
<input type="text" id="coordName" placeholder="Location name">
<label>Latitude:</label>
<input type="number" id="coordLat" step="0.000001" placeholder="32.0730">
<label>Longitude:</label>
<input type="number" id="coordLng" step="0.000001" placeholder="-81.0900">
<label>Type:</label>
<select id="coordType" style="width:100%;padding:8px;margin-top:5px;background:#1a1410;color:#c9a876;border:1px solid #8b7355;border-radius:3px;font-size:11px">
<option value="Haunted">Haunted</option>
<option value="Blessed">Blessed Safe Space</option>
<option value="Historic">Historic Location</option>
<option value="Church">Church</option>
<option value="Inn">Inn/Hotel</option>
<option value="Restaurant">Restaurant/Bar</option>
<option value="Monument">Monument</option>
<option value="Other">Other</option>
</select>
<label>Story/Description:</label>
<textarea id="coordStory" placeholder="Enter location story..." style="width:100%;padding:8px;margin-top:5px;background:#1a1410;color:#c9a876;border:1px solid #8b7355;border-radius:3px;font-family:Georgia,serif;font-size:11px;min-height:80px;box-sizing:border-box"></textarea>
<label style="margin-top:10px">Preview Voice:</label>
<select id="previewVoice" style="width:100%;padding:8px;margin-top:5px;background:#1a1410;color:#c9a876;border:1px solid #8b7355;border-radius:3px;font-size:11px">
<option value="OldLady">👵 Old Lady</option>
<option value="OldMan">👴 Old Man</option>
</select>
<button onclick="previewStory()" style="width:100%;padding:10px;margin-top:10px;background:#8b7355;color:#f5f5dc;border:none;border-radius:3px;cursor:pointer;font-size:11px;font-weight:bold">▶ Play Preview</button>
<div class="buttons">
<button onclick="saveCoordinates()" style="background:#66bb6a;margin:0;flex:2">Save Changes</button>
<button onclick="deleteLocation()" style="background:#c9534f;margin:0;flex:1">Delete</button>
<button onclick="closeCoordEditor()" style="background:#8b7355;margin:0">Cancel</button>
</div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
const locations=[{name:"The Wilder House - Safe Sanctuary",lat:32.063981,lng:-81.093259,type:"Blessed Safe Space",story:"314 East Park Avenue, near Forsyth Park. Reverend Wilder blessed this sanctuary centuries ago. The protection holds absolute—no spirit crosses this threshold. The living find refuge here. The dead cannot follow. Stand here, gather courage. To the west lies Forsyth Park and its dancing fountain. To the north, the Historic District and River Street await. This sanctuary is your anchor. Return here if the spirits grow too heavy."},{name:"Forsyth Park - Northern End",lat:32.068944,lng:-81.095756,type:"Haunted Park",story:"The northern end where phantom boot heels march in eternal rhythm—the ghost regiment of Confederate soldiers from Georgia. Witnesses documented seeing translucent figures in gray uniforms at dusk among the oldest live oaks. They patrol endlessly, caught in a 1863 battle loop that continues still. They cannot rest. They will not surrender. The ancient oaks shelter their restless march."},{name:"Forsyth Park - Iconic Fountain",lat:32.069242,lng:-81.095593,type:"Haunted Park",story:"The heart of the park where the iconic fountain casts its eternal spell. A woman in white dances at dusk—eternally young, eternally grieving—waltzing to music only she hears. She died on her wedding night in the 1890s and never left. The Fragrance Garden carries delicate scents mixed with sorrow. This is where the park's most iconic haunting persists. She dances still."},{name:"Forsyth Park - Southern Grove",lat:32.065383,lng:-81.096239,type:"Haunted Park",story:"Beneath Spanish moss and ancient live oaks, a different darkness dwells in the southern grove. Voices cry in Gullah, African tongues—the speech of the enslaved. Apparitions labor among the trees, and chains rattle in the darkness. This grove held encampments for enslaved people throughout Savannah's history. The ground has absorbed their anguish. The dead insist on being remembered."},{name:"Cathedral of St. John the Baptist",lat:32.073356,lng:-81.090982,type:"Blessed Church",story:"Built 1799. The cathedral's bells toll with power—spirits cannot cross. Inside, the living find sanctuary. Outside, the dead press against walls like moths to flame. This is sacred ground. Souls seeking refuge here escape the haunted streets beyond."},{name:"First African Baptist Church",lat:32.076750,lng:-81.093380,type:"Blessed Church",story:"Built 1819. The spire rises like a lighthouse guiding lost souls upward. Visitors sensitive to spirits report seeing apparitions moving toward the church at night, their trajectories intentional. They dissolve into light as they approach sanctuary. This is a threshold toward redemption."},{name:"Independent Presbyterian Church",lat:32.070793,lng:-81.093272,type:"Blessed Church",story:"Consecrated 1868. Stone walls shelter those fleeing the haunted streets. No apparition has ever been reported inside. No shadow darkens the interior. The protective power is absolute. The living are safe here from the reaching hands of the dead."},{name:"First Bryan Baptist Church",lat:32.081326,lng:-81.096289,type:"Historic Church",story:"Founded 1777—one of America's oldest independent Black churches. The Underground Railroad hid fugitive enslaved people beneath these floorboards. A sacred Kikongo cosmogram marks the basement—spiritual protection symbols. The ghosts here do not haunt—they guard. The dead insist the living remember."},{name:"Marshall House",lat:32.076906,lng:-81.088810,type:"Haunted Inn",story:"Built 1820. Servant girl Anne Powell leapt from Room 204 in 1888 and never left. She collects missing items in death what she was denied in life. An African American cook also remains, his laughter echoing at 3 AM. Nearby: Marshall House, Kehoe House, Davenport House, Sorrel-Weed House. This block holds multiple tragedies, multiple ghosts."},{name:"Kehoe House",lat:32.078308,lng:-81.090388,type:"Haunted Hotel",story:"Built 1851, converted to Civil War hospital. Yellow Fever killed more than bullets. Mary Marshall walks the halls in her proprietor's stride. Children's laughter echoes from empty rooms—young patients who died far from home. A phantom typewriter clacks at night. Someone still has a story to tell."},{name:"Davenport House",lat:32.076380,lng:-81.093513,type:"Haunted Inn",story:"Built 1896. In 1987, workers found a skeleton sealed in the walls—an unsolved murder from the past. A man in a top hat materializes in the gardens at dusk. A small girl screams in the parlor without warning. The walls remember violence the law never solved. The dead demand justice."},{name:"Mercer Williams House",lat:32.071362,lng:-81.095466,type:"Historic Mansion",story:"Built 1868. A boy fell from the roof onto iron fence in 1969. Danny Hansford was murdered here in 1981 (Midnight in the Garden of Good and Evil). Both still haunt—the boy walks the roofline at midnight eternally. Danny's presence is heavier, more anguished, demanding recognition. Cold spots follow visitors room to room."},{name:"Historic Mansion - River Street",lat:32.073014,lng:-81.092455,type:"Historic Mansion",story:"Tom haunts this house with meticulous precision. He checks windows, arranges furniture, keeps everything exactly as it was in life. Furniture shifts overnight. Doors lock themselves. Tom was obsessive in life. Death changed nothing. His disapproval is palpable when rooms are disturbed. His control is absolute."},{name:"Habersham Jr. Restaurant",lat:32.079614,lng:-81.089803,type:"Historic Restaurant",story:"Built 1771. The brick beneath the plaster bleeds red—a permanent wound. Habersham Jr. manifests near the staircase in colonial garb, his form wavering, doubting his own existence. Diners see him at tables. Temperature drops. Melancholy presses down. He's not angry. He's lost between the mansion he knew and the restaurant it's become."},{name:"The Marshall House Hotel",lat:32.068736,lng:-81.097230,type:"Haunted Inn",story:"Lottie was fourteen when she died. Now she haunts eternally—footsteps running through corridors, cold spots appearing, flowers blooming where none are planted. Guests dream of a girl in white beckoning them deeper. Lottie is not trapped. She is waiting."},{name:"Kehoe House Historic Inn",lat:32.077154,lng:-81.088388,type:"Bed and Breakfast",story:"The Kehoe children never left. Laughter erupts from empty rooms. Footsteps run the staircases. Toys move by invisible hands. Parents report their children seeing other children playing. The original family also manifests—apparitions in period dress, serene and protective. The dead inhabit this house as much as the living."},{name:"Sorrel-Weed House",lat:32.074130,lng:-81.094036,type:"Historic Mansion",story:"Savannah's darkest haunting. In the 1800s, Molly Sorrels had an affair. The scandal fractured her world. Her anguished sobs pierce the nights—the purest expression of human pain. The house pulses with emotional residue so thick visitors feel it physically in their chest. Cold spots intensify near the master bedroom. The dead cannot forgive what happened here."},{name:"City Hotel - Historic Building",lat:32.080903,lng:-81.092047,type:"Historic Building",story:"Built 1821 as City Hotel. Dr. Minis and James Stark dueled in the billiard room in 1832. Stark materialized in period clothing, replaying his death eternally. Bottles fly off shelves—the violence stored in the building's energy. Toby, a servant ghost, works in the basement, organizing, cleaning, preparing for guests who will never come. The living and dead share this space."},{name:"Pirate's House",lat:32.078080,lng:-81.084145,type:"Haunted Bar",story:"Built 1754. Pirates and sailor ghosts materialize at tables eternally. Phantom footsteps echo through smuggling tunnels beneath the building. Spectral crews load invisible cargo onto ghost ships at River Street. Apparitions in tricorn hats order phantom drinks no one can hear. The tavern still serves—the dead simply cannot pay."},{name:"Historic Restaurant",lat:32.080686,lng:-81.087769,type:"Haunted Restaurant",story:"Since 1800s, phantom guests wander the halls in period clothing. Apparitions sit at dinner tables, silverware moving with purpose, plates eternally full. Cold spots freeze diners. Footsteps echo on empty staircases. The living and dead dine together. The dead are polite. They simply refuse to leave."},{name:"Chippewa Square",lat:32.079927,lng:-81.091616,type:"Historic Square",story:"Savannah's oldest square, est. 1733. Phantom duelists reenact fatal encounters with tragic precision. A Revolutionary War general patrols the perimeter, guarding a victory that became defeat. Bull Street runs north-south: head north to Madison Square (7,000 war dead), south toward the mansions and churches, east toward River Street, west toward the Cathedral. Every direction holds stories."},{name:"Madison Square",lat:32.073526,lng:-81.093989,type:"Historic Square",story:"Built over 7,000 graves from October 1779 Battle of Savannah. Phantom soldiers march at dusk—defeated French and American regiments endlessly re-fighting. Icy drafts carry gunpowder and death. North: Monterey Square holds different violence (1981 murder). South: Johnson Square echoes with duels and war. East: Cathedral and churches offer sanctuary. West: Whitefield Square draws spectral congregations."},{name:"Monterey Square",lat:32.071502,lng:-81.094953,type:"Historic Square",story:"Bull & Wayne Streets. The 1981 Hansford murder fractured this square's spiritual energy. Shadows dance with sinuous purpose. The gazebo carries overwhelming sadness. South on Bull: Madison Square (7,000 war dead). North: Wright Square (Native displacement). East: Mercer Williams House (where the murder occurred). West: Whitefield Square (spectral prayers). Every direction offers darker stories."},{name:"Pulaski Square - Monument",lat:32.071357,lng:-81.094795,type:"Historic Monument",story:"This statue honors General Casimir Pulaski, hero of the 1779 siege. But Pulaski's duty did not end with his life. At midnight, phantom soldiers materialize around the monument and salute—a military ritual preserved in death. Cold wind swirls around the base year-round, regardless of weather patterns. The wind is not natural. It is the breath of fallen soldiers, forever honoring their commander."},{name:"Jackson Square",lat:32.075819,lng:-81.093147,type:"Historic Square",story:"Bull & McDonough Streets. Shadows move with intelligence among ancient oaks. Voices echo in Gullah, French, Native American—centuries layered. South on Bull: Forsyth Park and the dancing fountain. North on Bull: Monterey Square and its 1981 murder. East on McDonough: marshes and hidden paths where more spirits wander. West: churches and safe spaces. Walk any direction—each path leads deeper."},{name:"Oglethorpe Monument",lat:32.075790,lng:-81.093146,type:"Historic Monument",story:"General James Edward Oglethorpe, founder of Georgia, continues his watch from stone. Phantom colonial soldiers march around this monument at dusk in precise formation—soldiers he commanded in life still obey him in death. Apparitions in 18th-century dress materialize long enough to salute, their respect transcending the boundary between life and death. Cold spots freeze visitors who stand too close."},{name:"Wright Square",lat:32.077955,lng:-81.092299,type:"Historic Square",story:"Bull & President Streets. This square sits atop Yamacraw Village, home of Tomo-Chi-Chi and the Yamacraw people before European displacement. Phantom footsteps echo—moccasins on earth, a rhythm older than European Savannah. Cold drafts swirl around the Tomo-Chi-Chi monument, carrying voices in languages lost to time. The square replays the collision of civilizations."},{name:"Tomo-Chi-Chi Monument",lat:32.077955,lng:-81.092299,type:"Historic Monument",story:"This statue honors Tomo-Chi-Chi, the Yamacraw chief, but the honor is incomplete. Spirit voices whisper in native tongues around the monument—languages that no living person speaks. Phantom warriors materialize at dusk in traditional dress, their movements carrying the weight of history and loss. Apparitions in buckskin dance around the monument with ritualistic purpose."},{name:"Whitfield Square",lat:32.070223,lng:-81.090556,type:"Historic Square",story:"Named for the great evangelist George Whitefield (1714-1770). At twilight, a phantom congregation materializes—hundreds of spectral worshippers drawn by the eternal pull of a preacher's voice. Sermons echo from empty air. Apparitions in 18th-century dress kneel in synchronized prayer, their devotion absolute. They fade at darkness but return at twilight without fail."},{name:"Johnson Square",lat:32.078514,lng:-81.094572,type:"Historic Square",story:"The phantom footsteps of 18th-century figures echo across this square with regularity—the gait of aristocrats, the shuffle of servants, the determined stride of those with purpose. Cold spots near the monuments mark where spirits congregate, invisible conversations occurring in the spaces between heartbeats. Apparitions in colonial dress appear briefly before vanishing—a woman in a silk gown, a man in velvet, servants carrying invisible burdens."},{name:"Historic Mansion - Victory",lat:32.077716,lng:-81.087818,type:"Historic Mansion",story:"This 1820 mansion is inhabited by phantom residents who refuse to accept that the world has moved on. They wander the halls in period clothing, going about the routines of life as if the 200 years since their death have not transpired. Cold drafts emanate from locked rooms—the breath of spirits trapped in spaces they cannot escape. Apparitions appear in mirrors with startling clarity before vanishing."},{name:"Historic Mansion - Servants",lat:32.081164,lng:-81.097265,type:"Historic Mansion",story:"Within this historic mansion, spectral servants continue their labor eternally—invisible duties performed with the precision of those who spent their entire lives in service. Cold spots mark the bedrooms where they slept, where they died, where they remain. Apparitions materialize in doorways with purposeful presence, their expressions conveying both resignation and determination to complete their work."},{name:"River Bar - Sailors",lat:32.080603,lng:-81.089630,type:"River Haunt",story:"At closing time, drowned sailor spirits wander into this bar seeking one last drink, one final moment of camaraderie before returning to the cold river that claimed them. Phantom ship captains materialize at tables and order drinks from bartenders who cannot hear them, coins from the 18th century scattered on tables that no transactions will ever complete. Misty figures appear along the docks outside."},{name:"Historic Civic Center",lat:32.081136,lng:-81.091112,type:"Historic Building",story:"This colonial-era civic center holds power in its stone—the power to imprison, to judge, to sentence. Political prisoners languished in basement dungeons, their cries absorbed into the walls like water into thirsty earth. Phantom footsteps echo the corridors at midnight: the gait of guards, the shuffle of prisoners, the authoritative stride of those wielding civic power."},{name:"Historic Marketplace",lat:32.080819,lng:-81.094936,type:"Historic Market",story:"This colonial marketplace was more than a place of commerce—it was a place of human sale. The auction block that stood here has vanished in the physical world, but it endures in the spiritual realm. Phantom vendors materialize and fade in the space, their transactions involving commodities that humanity should never have bought or sold. Whispers of ancient commerce echo at night in languages spanning centuries."},{name:"Cotton Exchange",lat:32.080808,lng:-81.088539,type:"Historic Building",story:"This 1800s cotton exchange was the financial center of slavery itself—the hub around which billions of dollars in human suffering rotated. The anguish of enslaved peoples is literally embedded in the brick, seeping from mortar and stone. Phantom scales weigh invisible cotton bales, the scales never balancing because no quantity of cotton can equal the value of human lives."},{name:"Commercial Building - Workers",lat:32.080900,lng:-81.088900,type:"Historic Building",story:"This 1860s commercial structure was built by workers who understood labor, who understood burden. Now phantom workers labor in empty rooms at night, continuing the work that defined their lives even in death. Typewriter keys clatter from vacant offices—phantom typists recording transactions that have no monetary value, creating records that serve no business purpose."},{name:"Bonaventure Cemetery",lat:32.075136,lng:-81.089917,type:"Historic Cemetery",story:"At night, the Revolutionary War dead rise from beneath headstones and walk the pathways of this cemetery—soldiers checking their formations, officers accounting for their troops, the war continuing in death as it did in life. The screams of grave robbers echo eternally through the fog—those who desecrated the dead now experiencing the violation they inflicted in twisted, perpetual payback."},{name:"River Street Docks",lat:32.080586,lng:-81.086585,type:"River Haunt",story:"Beneath River Street cobblestones lies a colonial graveyard—unconsecrated dead, bodies disposed of rather than honored. At midnight, drowned sailors materialize from the Savannah River, water streaming from sodden clothes. 18th-century merchant ships manifest in fog—spectral vessels forever anchored here. Phantom crews load invisible cargo, sing sea shanties in languages centuries dead. The sailors do not acknowledge the living."},{name:"Warehouse District",lat:32.080898,lng:-81.091203,type:"River Haunt",story:"The Warehouse District remembers. It remembers the slave auctions that occurred here, the bodies catalogued and priced, the humanity stripped away transaction by transaction. Slave auction house spirits materialize among the warehouses, their expressions bearing witness to their own commodification. Whipping posts that no longer exist in the physical world stand solidly in the spiritual realm."},{name:"Bay Street Steps",lat:32.081200,lng:-81.086500,type:"River Haunt",story:"Thirty-three treacherous granite steps descend from Bay Street to River Street. Stone worn smooth by falling bodies—each step claims victims: drunk, careless, unlucky. Phantom screams pierce foggy nights—final cries of the fallen. At the bottom: River Street Docks and the drowned sailors. North: Factors Walk Tunnels (slave trade horrors). South: Warehouse District (auctions)."},{name:"Factors Walk Tunnels",lat:32.080033,lng:-81.085623,type:"Underground",story:"Beneath River Street lies a network of 1700s-1800s tunnels used for the slave trade—chambers carved from rock to hide humanity's greatest crime. The remains of the enslaved dead are literally entombed in brick and mortar. Their screams echo eternally without diminishment, as if time itself has stopped. Chains rattle in absolute darkness, the sound of bondage never released. The tunnels are a wound that will never heal."},{name:"Thunderbird Inn",lat:32.083348,lng:-81.094991,type:"Haunted Hotel",story:"Built 1892 as Savannah's premier luxury hotel. A woman in burgundy velvet manifests in mirrors, vanishing before she can be fully observed—eternally searching for something lost on her wedding night in 1894. Her perfume drifts through hallways with no living source. Guests report a gentleman in a top hat checking into empty rooms, leaving calling cards with names that change each time."},{name:"Armstrong House",lat:32.072950,lng:-81.090340,type:"Historic Mansion",story:"Just north of Forsyth Park, this historic home holds the presence of its original inhabitants. Footsteps echo through hallways at night—the pacing of those who never accepted departure. Cold spots appear in doorways. Visitors report seeing period-dressed figures moving through rooms with purposeful intent. The house breathes with the weight of centuries. The dead remain, tending to their eternal home."}];

const voiceMap={OldLady:"0rEo3eAjssGDUCXHYENf",OldMan:"dtVZnErhiiosqofxDzSH"};

const audioFileMap={
  "The Wilder House - Safe Sanctuary":{OldMan:"/audio/wilder-house-oldman.mp3",OldLady:"/audio/wilder-house-oldlady.mp3"}
};

let map,selectedLocation=null,geofencingActive=false,userLocation=null,markers=[],currentEditingIndex=null,adminMode=false;
const GEOFENCE_RADIUS=200;
const ADMIN_PASSWORD='savannah2024';

function initMap(){
map=L.map('map').setView([32.0730,-81.0900],14);
L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png',{
attribution:'Map data &copy; OpenStreetMap, CartoDB',maxZoom:19
}).addTo(map);

markers=[];
locations.forEach((loc,idx)=>{
const icon=L.divIcon({className:'location-dot '+(loc.type.includes('Blessed')?'blessed':'haunted'),html:'<div></div>',iconSize:[20,20]});
const marker=L.marker([loc.lat,loc.lng],{icon,draggable:adminMode}).addTo(map);
markers.push(marker);
marker.bindTooltip(loc.name,{permanent:true,direction:'right',offset:[10,0],className:'location-label'});
marker.on('click',()=>{
selectLocationByIndex(idx);
if(adminMode)openCoordEditor(idx);
});
marker.on('dragend',()=>{
if(!adminMode)return;
const newLat=marker.getLatLng().lat;
const newLng=marker.getLatLng().lng;
locations[idx].lat=parseFloat(newLat.toFixed(6));
locations[idx].lng=parseFloat(newLng.toFixed(6));
document.getElementById('coordLat').value=locations[idx].lat;
document.getElementById('coordLng').value=locations[idx].lng;
saveToStorage();
});
});

renderLocationList();
updateStats();
}

function selectLocationByIndex(idx){
selectedLocation=idx;
renderLocationList();
playNarration(idx);
}

async function playNarration(idx){
const loc=locations[idx];
const audio=document.getElementById('narrationAudio');
const selectedVoice=document.getElementById('voiceSelect').value;

if(audioFileMap[loc.name]&&audioFileMap[loc.name][selectedVoice]){
  audio.src=audioFileMap[loc.name][selectedVoice];
  audio.play();
  return;
}

const voiceId=voiceMap[selectedVoice]||voiceMap.George;
try{
const response=await fetch('https://api.elevenlabs.io/v1/text-to-speech/'+voiceId,{
method:'POST',
headers:{'xi-api-key':'sk_e7c4a94f287564d1b658fedd1752af90136987bc3a1c3ad8','Content-Type':'application/json'},
body:JSON.stringify({text:loc.name+' - '+loc.story})
});
if(response.ok){
const blob=await response.blob();
const url=URL.createObjectURL(blob);
audio.src=url;
audio.play();
}else{
console.log('Voice API: Demo mode');
}
}catch(e){
console.log('Voice narration - offline mode',e);
}
}

function renderLocationList(){
const list=document.getElementById('locationList');
list.innerHTML='';
locations.forEach((loc,idx)=>{
const card=document.createElement('div');
card.className='location-card'+(selectedLocation===idx?' active':'');
card.innerHTML='<div class="location-name">'+loc.name+'</div><div class="location-type">'+loc.type+'</div><div class="location-story">'+loc.story+'</div>';
card.onclick=()=>selectLocationByIndex(idx);
list.appendChild(card);
});
}

function centerMap(){
map.setView([32.0730,-81.0900],14);
}

function startGeofencing(){
if(!navigator.geolocation){alert('Geolocation not supported');return;}
geofencingActive=true;
document.querySelector('button:nth-of-type(2)').textContent='📍 Ghost Proximity Active';
navigator.geolocation.watchPosition(position=>{
userLocation={lat:position.coords.latitude,lng:position.coords.longitude};
checkNearbyLocations();
},error=>{
console.error('Geolocation error:',error);
geofencingActive=false;
document.querySelector('button:nth-of-type(2)').textContent='📍 Enable Voice Proximity';
});
}

function checkNearbyLocations(){
if(!userLocation||!geofencingActive)return;
const alert=document.getElementById('proximityAlert');
let nearby=[];
locations.forEach((loc,idx)=>{
const dist=getDistance(userLocation.lat,userLocation.lng,loc.lat,loc.lng);
if(dist<GEOFENCE_RADIUS){
nearby.push({name:loc.name,distance:dist,idx:idx});
}
});
if(nearby.length>0){
nearby.sort((a,b)=>a.distance-b.distance);
const closest=nearby[0];
alert.style.display='block';
alert.innerHTML='👻 '+closest.name+' ('+Math.round(closest.distance)+'m away)<br><small>Tap location to hear story</small>';
if(closest.distance<50&&!userLocation.lastPlayedIdx){
userLocation.lastPlayedIdx=closest.idx;
playNarration(closest.idx);
setTimeout(()=>{delete userLocation.lastPlayedIdx},30000);
}
}else{
alert.style.display='none';
}
}

function getDistance(lat1,lon1,lat2,lon2){
const R=6371;
const dLat=(lat2-lat1)*Math.PI/180;
const dLon=(lon2-lon1)*Math.PI/180;
const a=Math.sin(dLat/2)*Math.sin(dLat/2)+Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)*Math.sin(dLon/2);
const c=2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a));
return R*c*1000;
}

function updateStats(){
document.getElementById('totalCount').textContent=locations.length;
const haunted=locations.filter(l=>!l.type.includes('Blessed')).length;
const blessed=locations.filter(l=>l.type.includes('Blessed')).length;
document.getElementById('hauntedCount').textContent=haunted;
document.getElementById('blessedCount').textContent=blessed;
}

function openCoordEditor(idx){
const loc=locations[idx];
currentEditingIndex=idx;
document.getElementById('coordName').value=loc.name;
document.getElementById('coordLat').value=loc.lat;
document.getElementById('coordLng').value=loc.lng;
document.getElementById('coordType').value=loc.type.split(' ')[0];
document.getElementById('coordStory').value=loc.story;
document.getElementById('coordEditor').classList.add('active');
}

function closeCoordEditor(){
document.getElementById('coordEditor').classList.remove('active');
currentEditingIndex=null;
}

function saveCoordinates(){
if(currentEditingIndex===null)return;
const newName=document.getElementById('coordName').value.trim();
const newLat=parseFloat(document.getElementById('coordLat').value);
const newLng=parseFloat(document.getElementById('coordLng').value);
const newType=document.getElementById('coordType').value;
const newStory=document.getElementById('coordStory').value.trim();
if(!newName||isNaN(newLat)||isNaN(newLng)||!newStory){alert('Please fill all fields');return;}
const loc=locations[currentEditingIndex];
loc.name=newName;
loc.lat=newLat;
loc.lng=newLng;
loc.type=newType;
loc.story=newStory;
const marker=markers[currentEditingIndex];
if(marker){
marker.setLatLng([newLat,newLng]);
marker.bindTooltip(newName,{permanent:true,direction:'right',offset:[10,0],className:'location-label'});
}
renderLocationList();
closeCoordEditor();
alert('Location updated!');
}

function deleteLocation(){
if(currentEditingIndex===null)return;
if(!confirm('Delete this location permanently?'))return;
const locName=locations[currentEditingIndex].name;
locations.splice(currentEditingIndex,1);
const marker=markers[currentEditingIndex];
if(marker)map.removeLayer(marker);
markers.splice(currentEditingIndex,1);
currentEditingIndex=null;
saveToStorage();
initMap();
alert(locName+' deleted!');
}

function previewStory(){
const name=document.getElementById('coordName').value.trim();
const story=document.getElementById('coordStory').value.trim();
const voiceSelect=document.getElementById('previewVoice').value;
const voiceId=voiceMap[voiceSelect]||voiceMap.George;
if(!name||!story){
alert('Please enter location name and story first');
return;
}
const btn=event.target;
btn.textContent='⏳ Loading...';
btn.disabled=true;
fetch('https://api.elevenlabs.io/v1/text-to-speech/'+voiceId,{
method:'POST',
headers:{'xi-api-key':'sk_e7c4a94f287564d1b658fedd1752af90136987bc3a1c3ad8','Content-Type':'application/json'},
body:JSON.stringify({text:name+' - '+story})
}).then(response=>{
if(response.ok){
return response.blob();
}else{
alert('Voice API error - check API key');
btn.textContent='▶ Play Preview';
btn.disabled=false;
return null;
}
}).then(blob=>{
if(blob){
const url=URL.createObjectURL(blob);
const audio=new Audio(url);
audio.play();
btn.textContent='▶ Play Preview';
btn.disabled=false;
audio.onended=()=>{
URL.revokeObjectURL(url);
};
}
}).catch(e=>{
console.error('Preview error',e);
alert('Could not load preview - check connection');
btn.textContent='▶ Play Preview';
btn.disabled=false;
});
}

function promptAdminMode(){
const pwd=prompt('Enter admin password:');
if(pwd===null)return;
if(pwd===ADMIN_PASSWORD){
adminMode=true;
updateAdminUI();
alert('Admin mode unlocked!');
}else{
alert('Incorrect password');
}
}

function toggleAdminMode(){
adminMode=false;
updateAdminUI();
alert('Admin mode locked');
}

function updateAdminUI(){
const badge=document.getElementById('adminBadge');
const adminBtn=document.getElementById('adminButton');
const editBtn1=document.getElementById('editButton1');
const editBtn2=document.getElementById('editButton2');
if(adminMode){
badge.style.display='block';
adminBtn.style.display='none';
editBtn1.style.display='block';
editBtn2.style.display='block';
}else{
badge.style.display='none';
adminBtn.style.display='block';
editBtn1.style.display='none';
editBtn2.style.display='none';
}
}

function addNewLocation(){
const newLat=parseFloat(prompt('Enter latitude (e.g., 32.0730):'));
const newLng=parseFloat(prompt('Enter longitude (e.g., -81.0900):'));
if(isNaN(newLat)||isNaN(newLng)){alert('Invalid coordinates');return;}
const newName=prompt('Enter location name:');
if(!newName){return;}
const newType=prompt('Enter type (Haunted, Blessed, Historic, Church, etc.):','Haunted');
const newStory=prompt('Enter story/description:','');
if(!newStory){alert('Story cannot be empty');return;}
locations.push({name:newName,lat:newLat,lng:newLng,type:newType,story:newStory});
saveToStorage();
initMap();
alert(newName+' added! Total locations: '+locations.length);
}

function saveToStorage(){
localStorage.setItem('savannahGhostTourLocations',JSON.stringify(locations));
}

function loadFromStorage(){
const saved=localStorage.getItem('savannahGhostTourLocations');
if(saved){
try{
locations=JSON.parse(saved);
}catch(e){
console.error('Error loading saved locations',e);
}
}
}

function exportLocations(){
const exportData='// Savannah Ghost Tour - Location Data\n// Updated: '+new Date().toLocaleString()+'\n// Total Locations: '+locations.length+'\n\nconst locations=['+locations.map(l=>'{\n  name:"'+l.name.replace(/"/g,'\\"')+'",\n  lat:'+l.lat+',\n  lng:'+l.lng+',\n  type:"'+l.type.replace(/"/g,'\\"')+'",\n  story:"'+l.story.replace(/"/g,'\\"').replace(/\n/g,'\\n')+'"\n}').join(',\n')+'\n];\n';
const blob=new Blob([exportData],{type:'text/plain'});
const url=URL.createObjectURL(blob);
const a=document.createElement('a');
a.href=url;
a.download='savannah-locations-'+new Date().toISOString().split('T')[0]+'.txt';
a.click();
URL.revokeObjectURL(url);
alert('Locations exported! File downloaded.');
}

window.addEventListener('load',()=>{
loadFromStorage();
updateAdminUI();
initMap();
});
</script>
</body>
</html>
