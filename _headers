/* DEFAULT HEADERS FOR ALL PAGES */
/*
  /* SECURITY HEADERS */
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=(), payment=()

  /* CONTENT SECURITY POLICY */
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' 'wasm-unsafe-eval' https://cdnjs.cloudflare.com https://api.elevenlabs.io https://api.mapbox.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://api.mapbox.com https://fonts.googleapis.com; connect-src 'self' https://cdnjs.cloudflare.com https://api.mapbox.com https://web3forms.com https://google-analytics.com https://analytics.google.com https://cloudflareinsights.com https://static.cloudflareinsights.com https://api.open-meteo.com https://api.sunrise-sunset.org https://api.tidesandcurrents.noaa.gov https://catalog.archives.gov https://api.elevenlabs.io wss://api.elevenlabs.io https://a.tiles.mapbox.com https://b.tiles.mapbox.com https://c.tiles.mapbox.com https://d.tiles.mapbox.com; img-src 'self' data: blob: https:; font-src 'self' https://cdnjs.cloudflare.com https://fonts.gstatic.com; frame-src 'self'; object-src 'none'

  /* CACHING: HTML pages — always check freshness (no aggressive caching) */
  Cache-Control: public, max-age=0, must-revalidate
  Content-Type: text/html; charset=utf-8

/* STATIC ASSETS — Aggressive caching for immutable files */
/*.webp
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/webp

/*.{png,jpg,jpeg,gif,ico,svg}
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: image/svg+xml

/*.css
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: text/css; charset=utf-8

/*.js
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: application/javascript; charset=utf-8

/*.woff
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff

/*.woff2
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: font/woff2

/*.json
  Cache-Control: public, max-age=3600
  Content-Type: application/json; charset=utf-8

/*.mp3
  Cache-Control: public, max-age=31536000, immutable
  Content-Type: audio/mpeg
  Accept-Ranges: bytes

/*.webmanifest
  Cache-Control: public, max-age=604800
  Content-Type: application/manifest+json; charset=utf-8

